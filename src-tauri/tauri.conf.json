{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VecStructUI",
  "version": "0.1.0",
  "identifier": "com.ngerweck.structui-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "VecStructUI",
        "width": 1230,
        "height": 1000,
        "minWidth": 780,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:vecstructi.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
